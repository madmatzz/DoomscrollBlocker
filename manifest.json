{
  "manifest_version": 3,
  "name": "Doomscroll Blocker",
  "version": "1.0.0",
  "description": "Limit mindless scrolling on social media feeds and short videos. Set scroll limits, get interrupted, and take intentional breaks.",
  "permissions": [
    "storage",
    "alarms",
    "scripting"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.x.com/*",
        "*://*.reddit.com/*",
        "*://*.threads.net/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Doomscroll Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.ttf"],
      "matches": ["<all_urls>"]
    }
  ]
}